{
    "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "includes": ["**", "!!**/dist"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "html": {
        "experimentalFullSupportEnabled": true
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single"
        }
    },
    "overrides": [
        {
            "includes": ["**/*.vue"],
            "formatter": {
                "indentStyle": "space",
                "indentWidth": 4
            }
        }
    ]
}
